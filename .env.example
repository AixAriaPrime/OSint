# Required API Keys (leave blank to disable that integration)
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
HIBP_API_KEY=
LITELLM_API_KEY=

# LiteLLM model (e.g. gpt-4o-mini, claude-3-haiku-20240307, ollama/llama3)
AI_MODEL=gpt-4o-mini

# Redis (Docker Compose sets this automatically)
REDIS_URL=redis://redis:6379

# CORS — comma-separated list of frontend origins
CORS_ORIGINS=http://localhost:3000
