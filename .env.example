# Required API Keys (leave blank to disable that integration)
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
HIBP_API_KEY=
LITELLM_API_KEY=
HYBRID_ANALYSIS_API_KEY=
ANYRUN_API_KEY=

# Request signing -- callers must send HMAC-SHA256(body) in X-OmniTrace-Signature
# Leave blank to disable signature verification
HMAC_SECRET=

# LiteLLM model (e.g. gpt-4o-mini, claude-3-haiku-20240307, ollama/llama3)
AI_MODEL=gpt-4o-mini

# PostgreSQL — credentials used by postgres, pgbouncer, and backend
# DATABASE_URL is set automatically by Docker Compose (via pgbouncer); override for external DBs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=

# Redis (Docker Compose sets this automatically)
REDIS_URL=redis://redis:6379

# CORS — comma-separated list of allowed frontend origins
# For Docker deployments accessed from other machines, set this to the frontend URL
CORS_ORIGINS=http://localhost:3000

# Frontend API URL — baked into the Next.js bundle at build time
# Set to the public URL of your backend (e.g. https://api.yourdomain.com)
# If left blank, users can configure it at runtime from the in-app settings panel
NEXT_PUBLIC_API_URL=http://localhost:8000

# Grafana observability dashboard (http://localhost:3001)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
