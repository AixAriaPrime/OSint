{
  "id": null,
  "uid": "omnitrace-main",
  "title": "OmniTrace Observability",
  "description": "Agent activity, errors, security events, and audit trail for OmniTrace.",
  "tags": ["omnitrace", "osint", "loki"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests (24 h)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({log_type=\"audit\",job=\"omnitrace\"}[$__range]))",
          "legendFormat": "Requests",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errors (24 h)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 10 }
          ]
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({log_type=\"application\",job=\"omnitrace\"} |= \"ERROR\" [$__range]))",
          "legendFormat": "Errors",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Security Events (24 h)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 5 }
          ]
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({log_type=\"security\",job=\"omnitrace\"}[$__range]))",
          "legendFormat": "Security Events",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Rate Limit Hits (24 h)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({log_type=\"security\",job=\"omnitrace\"} |= \"Rate limit exceeded\" [$__range]))",
          "legendFormat": "Rate Limit Hits",
          "refId": "A",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({log_type=\"audit\",job=\"omnitrace\"}[$__interval]))",
          "legendFormat": "Requests/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error & Security Event Rate",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({log_type=\"application\",job=\"omnitrace\"} |= \"ERROR\" [$__interval]))",
          "legendFormat": "Errors/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(rate({log_type=\"security\",job=\"omnitrace\"}[$__interval]))",
          "legendFormat": "Security Events/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Security Events",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{log_type=\"security\",job=\"omnitrace\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Audit Trail",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{log_type=\"audit\",job=\"omnitrace\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Application Logs",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{log_type=\"application\",job=\"omnitrace\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ]
}
